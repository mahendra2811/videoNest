# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test/runtime artifacts
.playwright-mcp/
*.tsbuildinfo

# Serwist-generated service worker (regenerated on every build)
public/sw.js
public/sw.js.map
public/swe-worker-*.js

# Capacitor native build artifacts (the android/ and ios/ projects are
# created by `cap add` and may be committed; their build outputs are not)
/android/app/build/
/android/build/
/android/.gradle/
/ios/App/build/
/ios/App/Pods/
